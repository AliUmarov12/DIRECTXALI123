{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/",
      "destination": "/public/azcon-one.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
